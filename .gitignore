# ===========================================
# Phantom Reach - .gitignore
# ===========================================

# Dependencies
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# Next.js
.next/
out/
build/
next-env.d.ts

# Production build artifacts
dist/
*.tsbuildinfo
tsconfig.tsbuildinfo

# Environment & secrets
.env
.env.local
.env.*.local
.env.development.local
.env.production.local
.phantom-reach/

# Local database & runtime data
data/
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite-shm
*.sqlite-wal

# Generated reports, exports & analysis artifacts
output/
test-results/
playwright-report/
playwright/.cache/
.playwright-cli/

# Logs & debug artifacts
*.log
logs/
debug.html
debug-out.txt
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Editor / OS files
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/

# Local agent/tool state (keep shared configs, ignore local overrides)
.claude/settings.local.json

# Misc
*.pem
coverage/
.turbo/

